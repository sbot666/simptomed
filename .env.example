# Copy to .env.local and fill in your own values.

# Your Anthropic API key (or compatible proxy key).
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the API base URL (e.g. to route through a proxy).
# Default: https://api.anthropic.com
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional — override the model. Default: claude-opus-4.6
# ANTHROPIC_MODEL=claude-opus-4.6
